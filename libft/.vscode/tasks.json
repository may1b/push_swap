{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
        "label": "cc: compile",
        "type": "shell",
        "command": "cc",
        "args": [
            "-Wall",
            "-Wextra",
            "-Werror",
            "${file}",
            "-o",
            "${fileDirname}/${fileBasenameNoExtension}"
        ],
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "problemMatcher": ["$gcc"]
        },
        {
        "label": "cc: compile and run",
        "type": "shell",
        "command": "cc",
        "args": [
            "${file}",
            "-o",
            "${fileDirname}/${fileBasenameNoExtension}"
        ],
        "dependsOn": [],
        "problemMatcher": ["$gcc"],
        "presentation": {
            "reveal": "always"
        },
        "detail": "Compile and run current C file",
        "command": "sh",
        "args": [
            "-c",
            "cc \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\""
        ]
        }
    ],
    "version": "2.0.0"
}